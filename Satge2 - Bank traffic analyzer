**Core Script Structure:**
```python
import 
from scapy.all import rdpcap, IP, TCP, UDP
import json
from datetime import datetime

def analyze(pcap_file, threshold=100):
    packets = rdpcap(pcap_file)
    alerts  = []
    syn_count = {}

    for pkt in packets:
        if IP in pkt and TCP in pkt:
            src = pkt[IP].src
            # SYN scan detection
            if pkt[TCP].flags == 'S':
                syn_count[src] = syn_count.get(src, 0) + 1
                if syn_count[src] > threshold:
                    alerts.append({
                        'type'    : 'PORT_SCAN',
                        'src_ip'  : src,
                        'severity': 'HIGH',
                        'detail'  : f'{syn_count[src]} SYN packets'
                    })
    return alerts

if __name__ == '__main__':
    parser = argparse.ArgumentParser(description='BankTraffic Analyzer')
    parser.add_argument('--input',     required=True,  help='PCAP file path')
    parser.add_argument('--output',    default='results/report.json')
    parser.add_argument('--threshold', type=int, default=100)
    args = parser.parse_args()

    alerts = analyze(args.input, args.threshold)
    with open(args.output, 'w') as f:
        json.dump(alerts, f, indent=2)
    print(f"[+] Analysis complete — {len(alerts)} alerts → {args.output}")
```

